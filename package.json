{
  "name": "jackyang-portfolio",
  "version": "1.0.0",
  "description": "Personal website and portfolio of Jack Yang - XR Developer",
  "author": "Jack Yang <jackyangzzh@gmail.com>",
  "license": "MIT",
  "homepage": "https://jackyang.io",
  "repository": {
    "type": "git",
    "url": "https://github.com/jackyangzzh/jackyang.io"
  },
  "keywords": [
    "portfolio",
    "xr",
    "ar",
    "vr",
    "mixed-reality",
    "jekyll"
  ],
  "dependencies": {
    "re-template-tag": "^2.0.1"
  },
  "scripts": {
    "build:prod": "JEKYLL_ENV=production bundle exec jekyll build",
    "lighthouse:mobile": "start-server-and-test 'http-server _site -p 4001 -c-1 --silent' http://localhost:4001 'mkdir -p ./.lighthouse && lighthouse http://localhost:4001/ --only-categories=performance --output=html --output=json --output-path=./.lighthouse/mobile --chrome-flags=\"--headless=new\" --quiet'",
    "lighthouse:desktop": "start-server-and-test 'http-server _site -p 4001 -c-1 --silent' http://localhost:4001 'mkdir -p ./.lighthouse && lighthouse http://localhost:4001/ --preset=desktop --only-categories=performance --output=html --output=json --output-path=./.lighthouse/desktop --chrome-flags=\"--headless=new\" --quiet'",
    "lighthouse": "npm run build:prod && npm run lighthouse:mobile && npm run lighthouse:desktop"
  },
  "devDependencies": {
    "http-server": "^14.1.1",
    "lighthouse": "^12.8.2",
    "start-server-and-test": "^2.0.13"
  }
}
